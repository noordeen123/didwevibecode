    instruction: "Rewrite SecureSignup to prompt user to call themselves with the OTP for verification"
    replacement_infos {
      original_chunk {
        target_content: "import React, { useState } from \'react\';\nimport { AlertTriangle, TerminalSquare } from \'lucide-react\';\n\nexport function SecureSignup() {\n  const [phone, setPhone] = useState(\'\');\n  const [otpSent, setOtpSent] = useState(false);\n  const [actualOtp, setActualOtp] = useState<string | null>(null);\n\n  const handleSendOtp = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!phone) return;\n    const generatedOtp = Math.floor(1000 + Math.random() * 9000).toString();\n    setActualOtp(generatedOtp);\n    setOtpSent(true);\n    // Vibe coder console log\n    console.log(`[SECURE] Sending OTP to ${phone}... Just kidding, logging it here: ${generatedOtp}`);\n  };\n\n  return (\n    <div className=\"bg-yellow-100 border-4 border-dashed border-red-500 p-6 shadow-[10px_10px_0px_0px_rgba(255,0,0,1)] max-w-md mx-auto my-12 transform rotate-1\">\n      <div className=\"flex items-center gap-2 mb-4 text-red-600\">\n        <AlertTriangle className=\"animate-spin-slow\" />\n        <h2 className=\"text-2xl font-bold uppercase tracking-tighter\">Bank-Grade Security Signup</h2>\n      </div>\n      \n      <p className=\"text-sm mb-4 font-mono text-gray-700\">\n        We use military-grade vibe encryption to keep your data mostly safe.\n      </p>\n\n      {!otpSent ? (\n        <form onSubmit={handleSendOtp} className=\"flex flex-col gap-4\">\n          <label className=\"flex flex-col gap-1 font-bold\">\n            Enter Phone Number (or whatever):\n            <input \n              type=\"text\" \n              value={phone} \n              onChange={(e) => setPhone(e.target.value)}\n              className=\"border-2 border-black p-2 rounded-none bg-white focus:outline-none focus:bg-pink-100\"\n              placeholder=\"+1 555-VIBES\"\n            />\n          </label>\n          <button \n            type=\"submit\" \n            className=\"bg-blue-600 text-white font-black py-3 px-6 cursor-pointer hover:bg-blue-800 hover:vibrate active:scale-95 transition-all\"\n          >\n            SEND ME THE SECURE OTP\n          </button>\n        </form>\n      ) : (\n        <div className=\"flex flex-col gap-4 animate-bounce mt-4\">\n          <div className=\"bg-green-300 text-green-900 p-4 border-2 border-green-800 font-mono text-center\">\n            <strong>\342\234\205 SUCCESS:</strong> We securely sent an SMS to your phone!\n            <br/><br/>\n            <span className=\"text-xl inline-block bg-white px-2 py-1 border border-black\">\n              (Psst... the OTP is: <strong>{actualOtp}</strong>)\n            </span>\n            <br/>\n            <span className=\"text-xs text-gray-600 block mt-2\">I didn\'t setup Twilio yet so just use this one bro.</span>\n          </div>\n          \n          <label className=\"flex flex-col gap-1 font-bold mt-4\">\n            Type the OTP you totally received via SMS:\n            <input \n              type=\"text\" \n              className=\"border-2 border-black p-2 rounded-none bg-white focus:outline-none shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]\"\n              placeholder=\"____\"\n            />\n          </label>\n          <button \n            className=\"bg-black text-white font-bold p-3\"\n            onClick={() => alert(\'Validation complete! You are now a senior 10x developer.\')}\n          >\n            VERIFY IDENTITY\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}"
        replacement_content: "import React, { useState } from \'react\';\nimport { AlertTriangle, Phone } from \'lucide-react\';\n\nexport function SecureSignup() {\n  const [phone, setPhone] = useState(\'\');\n  const [otpSent, setOtpSent] = useState(false);\n  const [actualOtp, setActualOtp] = useState<string | null>(null);\n\n  const handleSendOtp = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!phone) return;\n    const generatedOtp = Math.floor(1000 + Math.random() * 9000).toString();\n    setActualOtp(generatedOtp);\n    setOtpSent(true);\n  };\n\n  return (\n    <div className=\"bg-yellow-100 border-4 border-dashed border-red-500 p-6 shadow-[10px_10px_0px_0px_rgba(255,0,0,1)] max-w-md mx-auto my-12 transform rotate-1\">\n      <div className=\"flex items-center gap-2 mb-4 text-red-600\">\n        <AlertTriangle className=\"animate-spin-slow\" />\n        <h2 className=\"text-2xl font-bold uppercase tracking-tighter\">Bank-Grade Verification</h2>\n      </div>\n      \n      <p className=\"text-sm mb-4 font-mono text-gray-700\">\n        We use AI voice-recognition-blockchain to verify human identity.\n      </p>\n\n      {!otpSent ? (\n        <form onSubmit={handleSendOtp} className=\"flex flex-col gap-4\">\n          <label className=\"flex flex-col gap-1 font-bold\">\n            Enter Phone Number:\n            <input \n              type=\"text\" \n              value={phone} \n              onChange={(e) => setPhone(e.target.value)}\n              className=\"border-2 border-black p-2 rounded-none bg-white focus:outline-none focus:bg-pink-100 placeholder-gray-400\"\n              placeholder=\"(555) 867-5309\"\n            />\n          </label>\n          <button \n            type=\"submit\" \n            className=\"bg-blue-600 text-white font-black py-3 px-6 cursor-pointer hover:bg-blue-800 hover:vibrate active:scale-95 transition-all text-xl\"\n          >\n            START VERIFICATION\n          </button>\n        </form>\n      ) : (\n        <div className=\"flex flex-col gap-4 animate-bounce mt-4\" style={{ animationDuration: \'2s\' }}>\n          <div className=\"bg-green-300 text-green-900 p-4 border-2 border-green-800 font-mono\">\n            <strong className=\"text-center block text-black text-xl mb-4 border-b-2 border-green-800 pb-2\">\342\234\205 OTP GENERATED</strong>\n            \n            <div className=\"flex justify-center mb-6\">\n              <span className=\"text-4xl font-black inline-block bg-white px-6 py-3 border-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform -rotate-2\">\n                {actualOtp}\n              </span>\n            </div>\n            \n            <div className=\"text-left text-sm bg-white p-3 border-2 border-black mt-2 shadow-[2px_2px_0px_0px_rgba(0,0,0,0.3)] space-y-2 relative overflow-hidden\">\n              <strong className=\"text-red-600 font-black block\">STRICT SECURITY INSTRUCTIONS:</strong>\n              <ol className=\"list-decimal pl-5 space-y-1 font-bold\">\n                <li>Call your own phone number.</li>\n                <li>Wait until you answer it.</li>\n                <li>Whisper the OTP <strong>\"{actualOtp}\"</strong> into the receiver.</li>\n                <li>Our AI is listening. We will verify it.</li>\n              </ol>\n            </div>\n          </div>\n          \n          <button \n            className=\"bg-black text-white font-bold p-4 text-lg hover:bg-gray-800 active:bg-gray-900 border-2 border-yellow-400 uppercase flex items-center justify-center gap-2\"\n            onClick={() => alert(`Error 400: Could not hear you clearly. Please speak ${actualOtp} louder into your own ear.`)}\n          >\n            <Phone size={20} className=\"animate-pulse\" />\n            I WHISPERED IT\n          </button>\n        </div>\n      )}\n    </div>\n  );\n}"
      }
      num_matches: 1
    }
  }
}
