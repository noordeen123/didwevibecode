      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { ServerCrash, Code2 } from \'lucide-react\';\n\nexport function Hero() {\n  const [errorCount, setErrorCount] = useState(0);\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      setErrorCount(prev => prev + Math.floor(Math.random() * 5));\n    }, 2000);\n    return () => clearInterval(interval);\n  }, []);\n\n  return (\n    <div className=\"relative py-20 px-8 text-center bg-gradient-to-r from-fuchsia-300 to-cyan-300 border-b-8 border-black\">\n      <div className=\"absolute top-4 left-4 flex gap-2\">\n        <span className=\"bg-red-500 text-white font-mono text-xs px-2 py-1 font-bold rounded flex items-center gap-1\">\n          <ServerCrash size={14} /> {errorCount} errors ignored\n        </span>\n        <span className=\"bg-gray-800 text-green-400 font-mono text-xs px-2 py-1 font-bold rounded\">\n          TS: any\n        </span>\n      </div>\n\n      <div className=\"absolute top-4 right-4 bg-yellow-300 transform rotate-12 border-2 border-black px-4 py-2 font-black text-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] vibrate\">\n        LGTM! \360\237\221\215\n      </div>\n\n      <div className=\"max-w-3xl mx-auto\">\n        <h1 className=\"text-5xl md:text-7xl font-black mb-6 text-black tracking-tighter drop-shadow-md\">\n          <span className=\"inline-block transform -rotate-3 text-pink-600\">vibe</span>\n          <span className=\"inline-block transform rotate-2\">_coding</span>\n          <span className=\"inline-block transform -rotate-6 text-blue-600\">.io</span>\n        </h1>\n        \n        <p className=\"text-2xl font-bold bg-white inline-block px-4 py-2 border-4 border-black mb-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]\">\n          \"I don\'t read errors, I just ask the AI to fix them\"\n        </p>\n\n        <div className=\"marquee-container bg-black text-green-400 font-mono text-sm py-2\">\n          <div className=\"marquee-content\">\n            console.log(\"here\"); console.log(\"here 2\"); console.log(\"pls work\"); alert(\"debug test\"); /* TODO: fix this later */ console.log(\"I am going insane\");\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
    }
